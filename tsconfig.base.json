{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@aliwei/domain": ["./packages/domain/src"],
      "@aliwei/domain/*": ["./packages/domain/src/*"],
      "@aliwei/db": ["./packages/db/src"],
      "@aliwei/db/*": ["./packages/db/src/*"],
      "@aliwei/ui": ["./packages/ui/src"],
      "@aliwei/ui/*": ["./packages/ui/src/*"]
    }
  }
}
