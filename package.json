{
  "name": "aliwei-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter web --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm --filter web build",
    "start": "pnpm -r --parallel --filter web --filter api start",
    "lint": "pnpm -r --parallel run lint",
    "format:fix": "pnpm -r --parallel run format:fix",
    "typecheck": "pnpm -r --parallel run typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0"
}
